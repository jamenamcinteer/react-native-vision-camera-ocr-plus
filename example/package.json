{
  "name": "example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prebuild": "expo prebuild",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios --device",
    "web": "expo start --web",
    "clean:ios": "rm -rf ios && expo prebuild --platform ios",
    "clean:android": "rm -rf android && expo prebuild --platform android",
    "postinstall": "patch-package",
    "check-expo": "expo install --check",
    "switch-versions": "node scripts/switch-versions.js",
    "use:expo-54": "node scripts/switch-versions.js expo-54",
    "use:next": "node scripts/switch-versions.js next",
    "use:latest": "node scripts/switch-versions.js latest",
    "test-version:android:expo-54": "yarn use:expo-54 && yarn clean:android && yarn android",
    "test-version:android:next": "yarn use:next && yarn clean:android && yarn android",
    "test-version:android:latest": "yarn use:latest && yarn clean:android && yarn android",
    "test-version:ios:expo-54": "yarn use:expo-54 && yarn clean:ios && yarn ios",
    "test-version:ios:next": "yarn use:next && yarn clean:ios && yarn ios",
    "test-version:ios:latest": "yarn use:latest && yarn clean:ios && yarn ios"
  },
  "dependencies": {
    "babel-preset-expo": "~55.0.18",
    "expo": "~55.0.25",
    "expo-build-properties": "~55.0.14",
    "expo-image-picker": "~55.0.12",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-nitro-image": "^0.14.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-vision-camera": "^5.0.9",
    "react-native-vision-camera-ocr-plus": "link:..",
    "react-native-vision-camera-worklets": "^5.0.9",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-arrow-functions": "^7.27.1",
    "@babel/plugin-transform-shorthand-properties": "^7.27.1",
    "@babel/plugin-transform-template-literals": "^7.27.1",
    "@babel/preset-env": "^7.29.2",
    "@types/react": "~19.2.14",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
